{
  "name": "tweaker",
  "private": true,
  "description": "",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "pnpm --filter '@tweaker/*' run build",
    "build:dev": "pnpm --parallel --filter '@tweaker/*' run build:dev",
    "example:node": "pnpm --filter '@examples/node' run dev",
    "example:web": "pnpm --filter '@examples/web' run dev",
    "dev": "pnpm run '/^(example:web|build:dev)$/'"
  },
  "author": "criitch@yandex.ru",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.1.36",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.12",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-combine-duplicated-selectors": "^10.0.3",
    "postcss-custom-media": "^12.0.0",
    "postcss-discard-empty": "^7.0.1",
    "postcss-import": "^16.1.1",
    "postcss-media-to-container": "^0.0.1",
    "postcss-nesting": "^14.0.0",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^6.0.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-live-preview": "^0.4.0",
    "vite-plugin-reload-on-rebuild": "0.0.4"
  }
}
