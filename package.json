{
  "name": "tweaker",
  "private": true,
  "description": "",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "pnpm --filter '@tweaker/*' run build",
    "build:dev": "pnpm --parallel --filter '@tweaker/*' run build:dev",
    "example:node": "pnpm --filter '@examples/node' run dev",
    "example:web": "pnpm --filter '@examples/web' run dev",
    "dev": "pnpm run '/^(example:web|build:dev)$/'"
  },
  "author": "criitch@yandex.ru",
  "license": "ISC",
  "devDependencies": {
    "@types/chrome": "^0.1.36",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
