{
  "manifest_version": 3,
  "name": "Tweaker DevTools Extension",
  "version": "1.0",
  "devtools_page": "devtools.html",
  "permissions": ["tabs", "scripting", "storage"],
  "action": {
    "default_title": "Tweaker DevTools"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-script.js"]
    }
  ],
  "background": {
    "service_worker": "background-service-worker.js",
    "type": "module"
  }
}
